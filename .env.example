# ============================================================
#  Premium Store — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to version control.
# ============================================================

# ── Flask ────────────────────────────────────────────────────────────────────
# A long, random string used to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_long_random_string

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Used to forward contact form submissions and order notifications to Telegram.
#
# Step-by-step setup:
#
#   1. Create a bot
#      - Open Telegram and search for @BotFather
#      - Send /newbot and follow the prompts
#      - Copy the token it gives you (looks like: 123456789:ABCdef...)
#
#   2. Get your Chat ID
#      - Send any message to your new bot
#      - Open this URL in a browser (replace TOKEN with your bot token):
#        https://api.telegram.org/bot<TOKEN>/getUpdates
#      - Find "chat" → "id" in the JSON response
#      - That number is your TELEGRAM_CHAT_ID
#      - For a group chat, add the bot to the group first, then send a message
#
#   3. Fill in the values below

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Optional: Running the app ─────────────────────────────────────────────────
# FLASK_ENV=development
# FLASK_DEBUG=1
